fn:int sum_head(xs:slice int) {
    return xs[0] + xs[1] + xs.length;
}

fn:int third(xs:slice int) {
    return xs[2];
}

fn:int main() {
    let data:int[4] = [3, 4, 5, 6];
    let view:slice int = data;
    let middle:slice int = view[1..3];
    let prefix:slice int = data[..2];
    let tail:slice int = [7, 8, 9][1..];

    return sum_head(middle) + prefix[1] + tail.length + third(data[1..]);
}
