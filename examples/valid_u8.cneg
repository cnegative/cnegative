struct Packet {
    kind:u8;
    payload:byte[2];
}

fn:byte choose(value:byte) {
    return if value == 0 { 1 } else { value };
}

fn:u8 main() {
    let kind:u8 = if true { 42 } else { 0 };
    let alias:byte = 0;
    let payload:byte[2] = [kind, choose(alias)];
    let packet:Packet = Packet {
        kind:kind,
        payload:payload
    };

    if packet.kind == 42 {
        print(packet.payload[1]);
    }

    if packet.payload[1] == 1 {
        return 0;
    }

    return 1;
}
