import std.net as net;
import std.strings as strings;
import std.time as time;
import std.env as env;
import std.parse as parse;

fn:int resolve_port() {
    let raw:result str = env.get("CNEGATIVE_NET_TEST_PORT");
    if raw.ok == false {
        return 34567;
    }

    if raw.ok {
        let parsed:result int = parse.to_int(raw.value);
        free raw.value;
        if parsed.ok {
            return parsed.value;
        }
    }

    return 34567;
}

fn:int main() {
    let port:int = resolve_port();
    let mut attempts:int = 0;
    let mut socket:result int = net.tcp_connect("127.0.0.1", port);
    while socket.ok == false {
        attempts = attempts + 1;
        if attempts == 50 {
            return 1;
        }

        time.sleep_ms(100);
        socket = net.tcp_connect("127.0.0.1", port);
    }

    if socket.ok {
        let sent:result int = net.send(socket.value, "ping");
        if sent.ok == false {
            let close_socket_on_send_error:result bool = net.close(socket.value);
            if close_socket_on_send_error.ok == false {
                return 2;
            }
            return 3;
        }

        let reply:result str = net.recv(socket.value, 32);
        if reply.ok == false {
            let close_socket_on_recv_error:result bool = net.close(socket.value);
            if close_socket_on_recv_error.ok == false {
                return 4;
            }
            return 5;
        }

        if reply.ok {
            if strings.eq(reply.value, "pong") == false {
                free reply.value;
                let close_socket_on_message_error:result bool = net.close(socket.value);
                if close_socket_on_message_error.ok == false {
                    return 6;
                }
                return 7;
            }

            free reply.value;
        }

        let close_socket:result bool = net.close(socket.value);
        if close_socket.ok == false {
            return 8;
        }

        return 0;
    }

    return 9;
}
