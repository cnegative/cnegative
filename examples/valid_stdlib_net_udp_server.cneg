import std.net as net;
import std.strings as strings;
import std.env as env;
import std.parse as parse;

fn:int resolve_port() {
    let raw:result str = env.get("CNEGATIVE_NET_TEST_PORT");
    if raw.ok == false {
        return 34567;
    }

    if raw.ok {
        let parsed:result int = parse.to_int(raw.value);
        free raw.value;
        if parsed.ok {
            return parsed.value;
        }
    }

    return 34567;
}

fn:int main() {
    let port:int = resolve_port();
    let socket:result int = net.udp_bind("", port);
    if socket.ok == false {
        return 1;
    }

    if socket.ok {
        let packet:result net.UdpPacket = net.udp_recv_from(socket.value, 64);
        if packet.ok == false {
            let close_socket_on_recv_error:result bool = net.close(socket.value);
            if close_socket_on_recv_error.ok == false {
                return 2;
            }

            return 3;
        }

        if packet.ok {
            if strings.eq(packet.value.data, "ping") == false {
                free packet.value.host;
                free packet.value.data;
                let close_socket_on_message_error:result bool = net.close(socket.value);
                if close_socket_on_message_error.ok == false {
                    return 4;
                }

                return 5;
            }

            if net.is_ipv4(packet.value.host) == false {
                free packet.value.host;
                free packet.value.data;
                let close_socket_on_host_error:result bool = net.close(socket.value);
                if close_socket_on_host_error.ok == false {
                    return 6;
                }

                return 7;
            }

            let reply:result int = net.udp_send_to(socket.value, packet.value.host, packet.value.port, "pong");
            free packet.value.host;
            free packet.value.data;
            if reply.ok == false {
                let close_socket_on_send_error:result bool = net.close(socket.value);
                if close_socket_on_send_error.ok == false {
                    return 8;
                }

                return 9;
            }

            let close_socket:result bool = net.close(socket.value);
            if close_socket.ok == false {
                return 10;
            }

            return 0;
        }
    }

    return 11;
}
