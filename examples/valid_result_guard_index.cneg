fn:result int main() {
    let data:int[3] = [9, 10, 11];
    let loaded:result slice int = ok data;

    let head:int = if loaded.ok { loaded.value[0] } else { 0 };
    let tail:slice int = if loaded.ok { loaded.value[1..] } else { data[..1] };

    while loaded.ok {
        return ok (head + tail[0] + loaded.value[2]);
    }

    return err;
}
